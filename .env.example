# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Milestone 1+ : Model access (used only by app/llm.py) ---
OPENAI_API_KEY=
# Optional: override the default model. Provider is swappable in app/llm.py.
OPENAI_MODEL=gpt-4o

# --- Milestone 3+ : Persistence (Postgres + Redis via docker-compose) ---
# DATABASE_URL=postgresql+psycopg://fde:fde@localhost:5432/fde_email_agent
# REDIS_URL=redis://localhost:6379/0

# --- Milestone 4+ : Slack (Socket Mode) ---
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_APPROVAL_CHANNEL=

# --- Milestone 5+ : Gmail (pull-based via Pub/Sub) ---
# GOOGLE_OAUTH_CLIENT_SECRETS=credentials.json
# GMAIL_PUBSUB_TOPIC=
